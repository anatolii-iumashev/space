# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=file:./data/space.db

# Optional path overrides (defaults come from space.config.json)
# DATA_DIR=./data
# FILES_DIR=./files

# File storage mode
# local (default if S3 keys are empty) | s3
# FILE_STORAGE=local

# Default user (bootstrapped on startup)
SPACE_USER_EMAIL=admin@example.com
SPACE_USER_PASSWORD=change-me
# SPACE_USER_NAME=Admin

# JWT
JWT_SECRET=change-me-in-production

# S3 (file storage)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=space-files
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# IMAP (email receiving)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# SMTP (email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# CalDAV
CALDAV_URL=https://apidata.googleusercontent.com/caldav/v2
CALDAV_USER=
CALDAV_PASS=

# Server
PORT=3000
HOST=0.0.0.0

# Client URL
CLIENT_URL=http://localhost:3001

# Allow user registration (disabled by default)
# APP_REGISTRATION_ENABLED=true
